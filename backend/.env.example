# Copy to /opt/tools/tools.env on the droplet (chmod 600). NEVER commit the real file.

# Owner-mode bearer for the tools API. DISTINCT from the chat's CHAT_TOKEN.
# Generate: openssl rand -hex 32
TOOLS_TOKEN=

# Claude — Map Maker auto-extract (URL/doc/image → Mermaid). Same key as the chat.
ANTHROPIC_API_KEY=
# Default claude-opus-4-8; set claude-sonnet-4-6 to match the chat (lower cost).
ANTHROPIC_MODEL=claude-opus-4-8

# DO Spaces (scoped Read/Write key for the sajivfrancis-tools bucket ONLY)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=sajivfrancis-tools
DO_SPACES_REGION=sfo3
DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
# Optional: serve via the CDN endpoint (…sfo3.cdn.digitaloceanspaces.com) or a custom
# subdomain. Leave blank to use the origin endpoint.
DO_SPACES_CDN_BASE=

# Comma-separated browser origins allowed to call the API.
ALLOWED_ORIGINS=https://sajivfrancis.com,https://www.sajivfrancis.com,https://tools.sajivfrancis.com,http://localhost:4321,http://127.0.0.1:4321

# Publish-to-site (owner-only "Save to site" button). Fine-grained GitHub PAT
# scoped to ONLY the site repo with Contents: Read and write.
SITE_GITHUB_TOKEN=
SITE_REPO=sfrancis2017/sajivfrancis.github.io
SITE_BRANCH=master
BANNER_DIR=public/img/banners
